{
  "$schema": "https://design-tokens.github.io/community-group/schemas/format/",
  "color": {
    "navy":           { "$value": "#0F1F38", "$type": "color", "$description": "Primary brand, headlines, nav" },
    "navy-mid":       { "$value": "#1C3254", "$type": "color", "$description": "Surfaces on dark, secondary navy" },
    "navy-light":     { "$value": "#2A4A73", "$type": "color", "$description": "Secondary text on dark, borders" },
    "stamp":          { "$value": "#C0392B", "$type": "color", "$description": "Seal/wordmark and critical gap status ONLY" },
    "stamp-deep":     { "$value": "#96201A", "$type": "color", "$description": "Critical status emphasis" },
    "parchment":      { "$value": "#F5F0E8", "$type": "color", "$description": "Page background, primary surface" },
    "parchment-deep": { "$value": "#EDE5D4", "$type": "color", "$description": "Card borders, dividers, ruled lines" },
    "parchment-dark": { "$value": "#C8B99A", "$type": "color", "$description": "Secondary text on parchment" },
    "ink":            { "$value": "#1A1A2E", "$type": "color", "$description": "Primary body text" },
    "ink-mid":        { "$value": "#4A4A6A", "$type": "color", "$description": "Secondary body text" },
    "ink-light":      { "$value": "#8A8AAA", "$type": "color", "$description": "Hints, metadata, placeholders" },
    "gold":           { "$value": "#B8860B", "$type": "color", "$description": "Pending status only" },
    "gold-light":     { "$value": "#D4A017", "$type": "color", "$description": "Pending emphasis" },
    "present":        { "$value": "#1D9E75", "$type": "color", "$description": "Document present / gap map green" },
    "off-white":      { "$value": "#FAFAF8", "$type": "color", "$description": "Alternating section background" },
    "white":          { "$value": "#FFFFFF", "$type": "color", "$description": "Card surfaces" },
    "red":            { "$value": "#C0392B", "$type": "color", "$description": "Legacy alias for stamp" },
    "green":          { "$value": "#1D9E75", "$type": "color", "$description": "Legacy alias for present" },
    "gray":           { "$value": "#F2F4F7", "$type": "color", "$description": "Legacy neutral surface" }
  }
}
